{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "$id": "",
  "description": "State message",
  "title": "State message for RMF2 AGVs",
  "modelTags": "",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "Property. NGSI Entity type. It has to be StateMessage",
      "enum": [
        "StateMessage"
      ]
    },
    "battery": {
      "type": "object",
      "properties": {
        "remainingPercentage": {
          "type": "integer",
          "description": "Remaining Battery Charge"
        }
      },
      "required": [
        "remainingPercentage"
      ]
    },
    "destination": {
      "type": "object",
      "properties": {
        "mapId": {
          "type": "string",
          "description": "Map ID"
        },
        "nodeId": {
          "type": "string",
          "description": "Corresponding Node ID"
        },
        "orientation2D": {
          "type": "object",
          "properties": {
            "theta": {
              "type": "number",
              "description": "2D Angle of the AGV"
            }
          },
          "required": [
            "theta"
          ]
        },
        "point2D": {
          "type": "object",
          "properties": {
            "x": {
              "type": "number",
              "default": 0,
              "description": "Property. Simple coordinate of a point"
            },
            "y": {
              "type": "number",
              "default": 0,
              "description": "Property. Simple coordinate of a point"
            }
          },
          "required": [
            "x",
            "y"
          ]
        },
        "released": {
          "type": "boolean",
          "description": "Determines if AGV is allowed to reach this point"
        },
        "sequenceId": {
          "type": "integer",
          "description": "Sequence ID of the node with respect to the waypoints route"
        }
      },
      "required": [
        "mapId",
        "nodeId",
        "orientation2D",
        "point2D",
        "released",
        "sequenceId"
      ]
    },
    "pose": {
      "type": "object",
      "properties": {
        "lastNodeSequenceId": {
          "type": "integer",
          "description": "The last traversed node's sequence ID with respect to the route"
        },
        "mapId": {
          "type": "string",
          "description": "Map ID"
        },
        "orientation2D": {
          "type": "object",
          "properties": {
            "theta": {
              "type": "number",
              "description": "2D Angle of the AGV"
            }
          },
          "required": [
            "theta"
          ]
        },
        "point2D": {
          "type": "object",
          "properties": {
            "x": {
              "type": "number",
              "default": 0,
              "description": "Property. Simple coordinate of a point"
            },
            "y": {
              "type": "number",
              "default": 0,
              "description": "Property. Simple coordinate of a point"
            }
          },
          "required": [
            "x",
            "y"
          ]
        }
      },
      "required": [
        "lastNodeSequenceId",
        "mapId",
        "orientation2D",
        "point2D"
      ]
    },
    "velocity": {
      "type": "object",
      "properties": {
        "omega": {
          "type": "number",
          "description": "The AGVs turning speed around its z axis."
        },
        "vx": {
          "type": "number",
          "description": "The AGVs velocity in its x direction"
        },
        "vy": {
          "type": "number",
          "description": "The AGVs velocity in its y direction"
        }
      },
      "required": [
        "omega",
        "vx",
        "vy"
      ]
    },
    "waypoints": {
      "type": "array",
      "description": "List of waypoints",
      "items": {
        "type": "object",
        "properties": {
          "nodeId": {
            "type": "string",
            "description": ""
          },
          "orientation2D": {
            "type": "object",
            "properties": {
              "theta": {
                "type": "number",
                "description": "2D Angle of the AGV"
              }
            },
            "required": [
              "theta"
            ]
          },
          "point2D": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number",
                "default": 0,
                "description": "Property. Simple coordinate of a point"
              },
              "y": {
                "type": "number",
                "default": 0,
                "description": "Property. Simple coordinate of a point"
              }
            },
            "required": [
              "x",
              "y"
            ]
          },
          "released": {
            "type": "boolean",
            "description": ""
          },
          "sequenceId": {
            "type": "integer",
            "description": ""
          }
        },
        "additionalProperties": false,
        "required": [
          "nodeId",
          "orientation2D",
          "point2D",
          "released",
          "sequenceId"
        ]
      }
    },
    "status": {
      "type": "string",
      "description": "State of the AGV"
    }
  },
  "required": [
    "type",
    "battery",
    "destination",
    "pose",
    "velocity",
    "waypoints",
    "status"
  ]
}